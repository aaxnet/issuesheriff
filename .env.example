# ─────────────────────────────────────────────
#  IssueSheriff — Environment Configuration
# ─────────────────────────────────────────────

# GitHub personal access token
# Required for: issuesheriff scan, issuesheriff reply, issuesheriff labels
# Scopes needed: repo (read issues), issues:write (apply labels)
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API key (recommended)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Model to use (optional, default: gpt-4o-mini)
# ISSUESHERIFF_MODEL=gpt-4o-mini

# ─── Ollama (local, no API key needed) ───────
# Start Ollama: ollama run mistral
# Then set:
# OLLAMA_MODEL=mistral
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Tuning ──────────────────────────────────
# Similarity threshold for duplicate detection (0.0–1.0)
# SIMILARITY_THRESHOLD=0.45
# Maximum issues to fetch per scan
# MAX_ISSUES=100
